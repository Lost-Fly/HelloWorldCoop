# Telegram Bot Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control!

# Your bot token from @BotFather (required)
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890

# Your bot username without @ symbol (required)
BOT_USERNAME=YourBotUsernameHere

# Usage:
# 1. Get your bot token from @BotFather on Telegram
# 2. Copy this file: cp .env.example .env
# 3. Edit .env and add your actual token and username
# 4. Source the file: source .env
# 5. Run the bot: ./run-bot.sh